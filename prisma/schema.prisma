generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Agent {
  id           String   @id @default(cuid())
  name         String
  role         String
  systemPrompt String
  model        String
  createdAt    DateTime @default(now())
}

model Portfolio {
  id        String   @id @default(cuid())
  balance   Float    @default(100000.0)
  trades    Trade[]
}

model Trade {
  id          String    @id @default(cuid())
  ticker      String
  quantity    Int
  price       Float
  type        String    // BUY o SELL
  portfolioId String
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id])
  timestamp   DateTime  @default(now())
}